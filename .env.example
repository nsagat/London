# ─────────────────────────────────────────────────────────────────────────────
# London — Bright Data configuration
#
# London works with NO credentials (it falls back to realistic mock/demo data),
# but the hackathon requires using a real Bright Data product. To go live, copy
# this file to `.env.local` and fill in your Bright Data API token + zone names.
#
#   cp .env.example .env.local
#
# When BRIGHT_DATA_API_KEY is present, the GTM "Route Task" flow makes real
# Bright Data calls (SERP API + MCP Server) and the UI shows a "LIVE" badge.
# ─────────────────────────────────────────────────────────────────────────────

# Your Bright Data API token (https://brightdata.com/cp/setting/users)
BRIGHT_DATA_API_KEY=

# Zone names created in your Bright Data dashboard
BRIGHT_DATA_SERP_ZONE=serp_api
BRIGHT_DATA_UNLOCKER_ZONE=web_unlocker

# Bright Data unified request endpoint (default is fine)
BRIGHT_DATA_REQUEST_ENDPOINT=https://api.brightdata.com/request

# Bright Data MCP server. The official server is published as @brightdata/mcp and
# is launched with npx; it reads the API token from API_TOKEN.
BRIGHT_DATA_MCP_COMMAND=npx
BRIGHT_DATA_MCP_ARGS=-y,@brightdata/mcp

# Optional — referenced as labeled pipeline steps, not required for the live demo
BRIGHT_DATA_WEB_SCRAPER_ENDPOINT=
BRIGHT_DATA_SCRAPING_BROWSER_URL=
