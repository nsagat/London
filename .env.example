# ─────────────────────────────────────────────────────────────────────────────
# London — Bright Data configuration
#
# London works with NO credentials (it falls back to realistic mock/demo data),
# but the hackathon requires using a real Bright Data product. To go live, copy
# this file to `.env.local` and add your Bright Data API token.
#
#   cp .env.example .env.local
#
# The live path runs through the Bright Data MCP server, which needs ONLY the
# API token — it provisions what it needs internally, so there is no zone setup.
# When the token is present, the GTM "Route Task" flow makes real Bright Data
# calls (MCP search_engine + scrape_as_markdown) and the UI shows a "LIVE" badge.
# ─────────────────────────────────────────────────────────────────────────────

# Your Bright Data API token (https://brightdata.com/cp/setting/users)
BRIGHT_DATA_API_KEY=

# Bright Data MCP server (primary live path — token-only, no zones needed)
BRIGHT_DATA_MCP_COMMAND=npx
BRIGHT_DATA_MCP_ARGS=-y,@brightdata/mcp

# ── Optional direct-HTTP fallback ────────────────────────────────────────────
# Only used if the MCP path is unavailable. Requires zones created in the Bright
# Data dashboard and a token with zone access. Safe to leave as defaults.
BRIGHT_DATA_SERP_ZONE=serp_api
BRIGHT_DATA_UNLOCKER_ZONE=web_unlocker
BRIGHT_DATA_REQUEST_ENDPOINT=https://api.brightdata.com/request
